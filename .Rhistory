model_dataset %>%
summarise(
# Dataset size
total_flights = n(),
matched_weather = sum(!is.na(tmpf)),
match_rate = round(matched_weather / total_flights * 100, 2),
# Dependent variables (Y1 and Y2)
avg_propagated_delay = mean(as.numeric(LATE_AIRCRAFT_DELAY), na.rm = TRUE),
max_propagated_delay = max(as.numeric(LATE_AIRCRAFT_DELAY), na.rm = TRUE),
pct_high_risk = mean(AWR, na.rm = TRUE) * 100,
# Weather variables (X)
avg_temperature = mean(tmpf, na.rm = TRUE),
avg_visibility_miles = mean(vsby, na.rm = TRUE),
avg_wind_speed_knots = mean(sknt, na.rm = TRUE),
max_wind_gust = max(gust, na.rm = TRUE),
avg_ceiling_ft = mean(ceiling_ft[ceiling_ft < 99999], na.rm = TRUE),
pct_low_ceiling = mean(ceiling_ft < 1000, na.rm = TRUE) * 100
) %>%
print()
# Complete summary with all metrics - PRINTED CLEARLY
summary_stats <- model_dataset %>%
summarise(
# Dataset size
total_flights = n(),
matched_weather = sum(!is.na(tmpf)),
match_rate = round(matched_weather / total_flights * 100, 2),
# Dependent variables (Y1 and Y2)
avg_propagated_delay = mean(as.numeric(LATE_AIRCRAFT_DELAY), na.rm = TRUE),
max_propagated_delay = max(as.numeric(LATE_AIRCRAFT_DELAY), na.rm = TRUE),
pct_high_risk = mean(AWR, na.rm = TRUE) * 100,
# Weather variables (X)
avg_temperature_F = mean(tmpf, na.rm = TRUE),
avg_visibility_miles = mean(vsby, na.rm = TRUE),
avg_wind_speed_knots = mean(sknt, na.rm = TRUE),
max_wind_gust_knots = max(gust, na.rm = TRUE),
avg_ceiling_ft = mean(ceiling_ft[ceiling_ft < 99999], na.rm = TRUE),
pct_low_ceiling = mean(ceiling_ft < 1000, na.rm = TRUE) * 100
)
# Print each value on a new line for clarity
cat("\n=== MODEL DATASET SUMMARY STATISTICS ===\n")
cat("Total flights:", summary_stats$total_flights, "\n")
cat("Matched with weather:", summary_stats$matched_weather, "\n")
cat("Match rate (%):", summary_stats$match_rate, "\n")
cat("\n--- Dependent Variables ---\n")
cat("Average propagated delay (minutes):", round(summary_stats$avg_propagated_delay, 2), "\n")
cat("Maximum propagated delay (minutes):", summary_stats$max_propagated_delay, "\n")
cat("High risk (AWR = 1) percentage:", round(summary_stats$pct_high_risk, 2), "%\n")
cat("\n--- Weather Variables ---\n")
cat("Average temperature (°F):", round(summary_stats$avg_temperature_F, 2), "\n")
cat("Average visibility (miles):", round(summary_stats$avg_visibility_miles, 2), "\n")
cat("Average wind speed (knots):", round(summary_stats$avg_wind_speed_knots, 2), "\n")
cat("Maximum wind gust (knots):", summary_stats$max_wind_gust_knots, "\n")
cat("Average ceiling height (feet):", round(summary_stats$avg_ceiling_ft, 2), "\n")
cat("Low ceiling (<1000 ft) percentage:", round(summary_stats$pct_low_ceiling, 2), "%\n")
# High risk percentage by airport
cat("\n=== HIGH RISK (AWR) BY AIRPORT ===\n")
model_dataset %>%
filter(!is.na(AWR)) %>%
group_by(ORIGIN) %>%
summarise(
total_flights = n(),
high_risk_count = sum(AWR == 1),
high_risk_pct = round(high_risk_count / total_flights * 100, 2)
) %>%
arrange(desc(high_risk_pct)) %>%
print()
# Average propagated delay under different weather conditions
cat("\n=== PROPAGATED DELAY BY WEATHER CONDITIONS ===\n")
model_dataset %>%
filter(!is.na(tmpf)) %>%
mutate(
weather_condition = case_when(
AWR == 1 ~ "High Risk (AWR=1)",
vsby < 5 ~ "Low Visibility",
sknt > 20 ~ "High Wind",
TRUE ~ "Normal Conditions"
)
) %>%
group_by(weather_condition) %>%
summarise(
flights = n(),
avg_delay = mean(as.numeric(LATE_AIRCRAFT_DELAY), na.rm = TRUE),
pct_of_total = round(flights / n() * 100, 2)
) %>%
arrange(desc(avg_delay)) %>%
print()
# Prepare final dataset for regression (remove missing values)
model_data_clean <- model_dataset %>%
filter(!is.na(tmpf), !is.na(AWR)) %>%
mutate(
# Convert delay to numeric
propagated_delay = as.numeric(LATE_AIRCRAFT_DELAY),
# Create airport dummy variables
is_JFK = ifelse(ORIGIN == "JFK", 1, 0),
is_ATL = ifelse(ORIGIN == "ATL", 1, 0),
is_ORD = ifelse(ORIGIN == "ORD", 1, 0),
is_DFW = ifelse(ORIGIN == "DFW", 1, 0),
is_LAX = ifelse(ORIGIN == "LAX", 1, 0)
)
# Save clean dataset
write_csv(model_data_clean, "model_data_clean.csv")
cat("Clean dataset saved:", nrow(model_data_clean), "rows\n")
# Load required libraries
library(tidyverse)
library(glmnet)
library(caret)
# Load clean data
model_data <- read_csv("model_data_clean.csv")
# Prepare data for Lasso
set.seed(123)
lasso_data <- model_data %>%
select(
propagated_delay,
tmpf, vsby, sknt, gust, ceiling_ft,
is_JFK, is_ATL, is_ORD, is_DFW, is_LAX
) %>%
drop_na()
# Create feature matrix X and target Y
X <- as.matrix(lasso_data %>% select(-propagated_delay))
Y <- lasso_data$propagated_delay
# Train Lasso model with cross-validation
cv_lasso <- cv.glmnet(X, Y, alpha = 1)
# View results
cat("\n=== LASSO REGRESSION RESULTS ===\n")
cat("Best lambda:", cv_lasso$lambda.min, "\n")
cat("R-squared:", max(1 - cv_lasso$cvm / var(Y)), "\n")
# Get coefficients
coef_lasso <- coef(cv_lasso, s = "lambda.min")
important_features <- as.matrix(coef_lasso)[which(as.matrix(coef_lasso) != 0), ]
cat("\nImportant Features (non-zero coefficients):\n")
print(important_features)
# Load required libraries
library(randomForest)
library(caret)
# Prepare data for Random Forest
set.seed(123)
rf_data <- model_data %>%
select(
AWR,
tmpf, vsby, sknt, gust, ceiling_ft,
is_JFK, is_ATL, is_ORD, is_DFW, is_LAX
) %>%
drop_na() %>%
mutate(AWR = as.factor(AWR))
# Take sample for faster training (20% of data)
rf_sample <- rf_data %>% sample_frac(0.2)
# Train Random Forest
rf_model <- randomForest(
AWR ~ .,
data = rf_sample,
ntree = 100,
importance = TRUE
)
# View results
cat("\n=== RANDOM FOREST RESULTS ===\n")
print(rf_model)
# Feature importance
cat("\n=== FEATURE IMPORTANCE ===\n")
importance_df <- as.data.frame(importance(rf_model))
importance_df$feature <- rownames(importance_df)
importance_df %>%
arrange(desc(MeanDecreaseGini)) %>%
select(feature, MeanDecreaseGini) %>%
head(10) %>%
print()
# Use a real operational target instead of AWR
rf_data_correct <- model_data %>%
mutate(
# Option 1: Use Carrier Delay as proxy for duty violations
duty_violation = ifelse(CARRIER_DELAY > 15, 1, 0),
# Option 2: Use your original formula with arrival delay
duty_violation_v2 = ifelse(ARR_DELAY > 30, 1, 0)
) %>%
select(
duty_violation,  # New target
tmpf, vsby, sknt, gust, ceiling_ft,
is_JFK, is_ATL, is_ORD, is_DFW, is_LAX
) %>%
drop_na() %>%
mutate(duty_violation = as.factor(duty_violation))
# Use a real operational target instead of AWR
rf_data_correct <- model_data %>%
mutate(
# Option 1: Use Carrier Delay as proxy for duty violations
duty_violation = ifelse(CARRIER_DELAY > 15, 1, 0),
# Option 2: Use your original formula with arrival delay
duty_violation_v2 = ifelse(ARR_DELAY > 30, 1, 0)
) %>%
select(
duty_violation,  # New target
tmpf, vsby, sknt, gust, ceiling_ft,
is_JFK, is_ATL, is_ORD, is_DFW, is_LAX
) %>%
drop_na() %>%
mutate(duty_violation = as.factor(duty_violation))
library(tidyverse)
library(lubridate)
library(ggplot2)
library(scales)
# Load your clean data
model_data <- read_csv("model_data_clean.csv")
# ============================================
# VISUALIZATION 1: High Risk Percentage by Airport
# ============================================
airport_risk <- model_data %>%
filter(!is.na(AWR)) %>%
group_by(ORIGIN) %>%
summarise(
total_flights = n(),
high_risk_count = sum(AWR == 1),
high_risk_pct = high_risk_count / total_flights * 100
) %>%
mutate(ORIGIN = factor(ORIGIN, levels = ORIGIN[order(high_risk_pct, decreasing = TRUE)]))
p1 <- ggplot(airport_risk, aes(x = ORIGIN, y = high_risk_pct, fill = ORIGIN)) +
geom_col(width = 0.7) +
geom_text(aes(label = paste0(round(high_risk_pct, 1), "%")),
vjust = -0.5, size = 5, fontface = "bold") +
scale_fill_manual(values = c("JFK" = "#E41A1C", "ATL" = "#FF7F00",
"ORD" = "#377EB8", "DFW" = "#4DAF4A",
"LAX" = "#984EA3", "SFO" = "#A65628")) +
labs(
title = "High Risk Weather Events by Airport",
subtitle = "Percentage of flights with visibility < 3 miles, ceiling < 1000 ft, or gusts > 25 knots",
x = "Airport",
y = "High Risk (%)",
caption = "Source: ASOS Weather Data 2025"
) +
theme_minimal() +
theme(
plot.title = element_text(size = 16, face = "bold"),
plot.subtitle = element_text(size = 11, color = "gray40"),
axis.title = element_text(size = 12),
axis.text = element_text(size = 11),
legend.position = "none"
)
ggsave("p1_airport_risk.png", p1, width = 8, height = 6, dpi = 300)
print(p1)
============================================
# ============================================
# VISUALIZATION 3: Wind Speed vs Propagated Delay
# ============================================
p3 <- model_data %>%
filter(!is.na(sknt), !is.na(LATE_AIRCRAFT_DELAY), sknt <= 40) %>%
mutate(wind_category = cut(sknt, breaks = c(0, 5, 10, 15, 20, 25, 100),
labels = c("0-5", "6-10", "11-15", "16-20", "21-25", "25+"))) %>%
group_by(wind_category) %>%
summarise(
avg_delay = mean(as.numeric(LATE_AIRCRAFT_DELAY), na.rm = TRUE),
flights = n()
) %>%
ggplot(aes(x = wind_category, y = avg_delay, fill = wind_category)) +
geom_col(width = 0.7) +
geom_text(aes(label = round(avg_delay, 1)), vjust = -0.5, size = 4) +
scale_fill_gradient2(low = "#4DAF4A", mid = "#FF7F00", high = "#E41A1C", guide = "none") +
labs(
title = "Wind Speed Impact on Propagated Delay",
subtitle = "Higher wind speeds lead to longer delays",
x = "Wind Speed (knots)",
y = "Average Propagated Delay (minutes)"
) +
theme_minimal() +
theme(
plot.title = element_text(size = 16, face = "bold"),
plot.subtitle = element_text(size = 11, color = "gray40"),
axis.title = element_text(size = 12)
)
ggsave("p3_wind_delay.png", p3, width = 8, height = 6, dpi = 300)
# ============================================
# VISUALIZATION 4: Visibility vs Propagated Delay
# ============================================
p4 <- model_data %>%
filter(!is.na(vsby), !is.na(LATE_AIRCRAFT_DELAY), vsby <= 20) %>%
mutate(visibility_category = cut(vsby, breaks = c(0, 1, 2, 3, 5, 10, 100),
labels = c("<1", "1-2", "2-3", "3-5", "5-10", "10+"))) %>%
group_by(visibility_category) %>%
summarise(
avg_delay = mean(as.numeric(LATE_AIRCRAFT_DELAY), na.rm = TRUE),
flights = n()
) %>%
ggplot(aes(x = visibility_category, y = avg_delay, fill = visibility_category)) +
geom_col(width = 0.7) +
geom_text(aes(label = round(avg_delay, 1)), vjust = -0.5, size = 4) +
scale_fill_manual(values = c("<1" = "#E41A1C", "1-2" = "#FF7F00",
"2-3" = "#FFD700", "3-5" = "#9ECAE1",
"5-10" = "#4DAF4A", "10+" = "#2E7D32"), guide = "none") +
labs(
title = "Visibility Impact on Propagated Delay",
subtitle = "Poor visibility (< 3 miles) significantly increases delays",
x = "Visibility (miles)",
y = "Average Propagated Delay (minutes)"
) +
theme_minimal() +
theme(
plot.title = element_text(size = 16, face = "bold"),
plot.subtitle = element_text(size = 11, color = "gray40"),
axis.title = element_text(size = 12)
)
ggsave("p4_visibility_delay.png", p4, width = 8, height = 6, dpi = 300)
print(p4)
# ============================================
# VISUALIZATION 5: Monthly High Risk Pattern
# ============================================
p5 <- model_data %>%
filter(!is.na(AWR), !is.na(dep_local)) %>%
mutate(
month = month(dep_local, label = TRUE, abbr = FALSE),
month_num = month(dep_local)
) %>%
group_by(month, month_num) %>%
summarise(
high_risk_pct = mean(AWR, na.rm = TRUE) * 100,
flights = n()
) %>%
arrange(month_num) %>%
ggplot(aes(x = month, y = high_risk_pct, group = 1)) +
geom_line(size = 1.5, color = "#E41A1C") +
geom_point(size = 3, color = "#E41A1C") +
geom_hline(yintercept = mean(model_data$AWR, na.rm = TRUE) * 100,
linetype = "dashed", color = "gray50", alpha = 0.7) +
annotate("text", x = 6.5, y = 11, label = "Average: 10.0%", size = 4, color = "gray50") +
labs(
title = "Seasonal Pattern of High Risk Weather Events",
subtitle = "Higher risk during spring and fall months",
x = "Month",
y = "High Risk Weather (%)",
caption = "Dashed line shows annual average"
) +
theme_minimal() +
theme(
plot.title = element_text(size = 16, face = "bold"),
plot.subtitle = element_text(size = 11, color = "gray40"),
axis.title = element_text(size = 12),
axis.text.x = element_text(angle = 45, hjust = 1)
)
ggsave("p5_monthly_risk.png", p5, width = 10, height = 6, dpi = 300)
print(p5)
# ============================================
# VISUALIZATION 6: Lasso Regression Coefficients
# ============================================
# Extract Lasso coefficients from your earlier model
coef_data <- data.frame(
feature = c("Wind Speed", "Wind Gust", "Temperature", "Visibility",
"Ceiling Height", "JFK", "ATL", "DFW", "LAX", "ORD"),
coefficient = c(0.241, 0.088, -0.045, -0.108, -0.008, -5.934, -10.222, 2.602, -3.608, NA)
) %>%
filter(!is.na(coefficient))
coef_data <- coef_data %>%
mutate(
direction = ifelse(coefficient > 0, "Increases Delay", "Decreases Delay"),
feature = factor(feature, levels = feature[order(coefficient)])
)
p6 <- ggplot(coef_data, aes(x = feature, y = coefficient, fill = direction)) +
geom_col(width = 0.7) +
geom_hline(yintercept = 0, color = "black", size = 0.5) +
coord_flip() +
scale_fill_manual(values = c("Increases Delay" = "#E41A1C", "Decreases Delay" = "#4DAF4A")) +
labs(
title = "Lasso Regression: Weather Impact on Propagated Delay",
subtitle = "Positive coefficients increase delay, negative coefficients decrease delay",
x = "Feature",
y = "Coefficient (minutes)",
caption = "Reference airport: ORD (Chicago)"
) +
theme_minimal() +
theme(
plot.title = element_text(size = 16, face = "bold"),
plot.subtitle = element_text(size = 11, color = "gray40"),
axis.title = element_text(size = 12),
axis.text = element_text(size = 10),
legend.position = "bottom"
)
ggsave("p6_lasso_coefficients.png", p6, width = 8, height = 6, dpi = 300)
print(p6)
# ============================================
# VISUALIZATION 7: Random Forest Feature Importance
# ============================================
# Feature importance from your Random Forest model
importance_plot <- importance_df %>%
arrange(desc(MeanDecreaseGini)) %>%
head(8) %>%
mutate(feature = factor(feature, levels = feature[order(MeanDecreaseGini)])) %>%
ggplot(aes(x = feature, y = MeanDecreaseGini, fill = feature)) +
geom_col(width = 0.7) +
coord_flip() +
scale_fill_viridis_d(guide = "none") +
labs(
title = "Random Forest: Feature Importance for High Risk Prediction",
subtitle = "Wind gust and wind speed are the most important predictors",
x = "Feature",
y = "Mean Decrease Gini (Importance)"
) +
theme_minimal() +
theme(
plot.title = element_text(size = 16, face = "bold"),
plot.subtitle = element_text(size = 11, color = "gray40"),
axis.title = element_text(size = 12),
axis.text = element_text(size = 10)
)
ggsave("p7_feature_importance.png", importance_plot, width = 8, height = 6, dpi = 300)
print(importance_plot)
# ============================================
# SUMMARY TABLE FOR REPORT
# ============================================
summary_table <- model_data %>%
summarise(
`Total Flights` = format(n(), big.mark = ","),
`Weather Match Rate` = paste0(round(sum(!is.na(tmpf)) / n() * 100, 1), "%"),
`Avg Propagated Delay` = paste0(round(mean(as.numeric(LATE_AIRCRAFT_DELAY), na.rm = TRUE), 1), " min"),
`High Risk (AWR=1)` = paste0(round(mean(AWR, na.rm = TRUE) * 100, 1), "%"),
`Avg Visibility` = paste0(round(mean(vsby, na.rm = TRUE), 1), " miles"),
`Avg Wind Speed` = paste0(round(mean(sknt, na.rm = TRUE), 1), " knots"),
`Avg Ceiling` = paste0(round(mean(ceiling_ft[ceiling_ft < 99999], na.rm = TRUE), 0), " ft")
) %>%
pivot_longer(everything(), names_to = "Metric", values_to = "Value")
print(summary_table)
# Save summary table as CSV
write_csv(summary_table, "summary_statistics.csv")
cat("\n✅ All visualizations saved as PNG files in your working directory\n")
cat("Files created:\n")
cat("  - p1_airport_risk.png\n")
