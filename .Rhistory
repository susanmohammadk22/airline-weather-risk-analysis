cat("  - summary_statistics.csv\n")
# ============================================
# VISUALIZATION 2: Propagated Delay by Weather Condition (FIXED)
# ============================================
delay_by_weather <- model_data %>%
filter(!is.na(tmpf), !is.na(AWR)) %>%
mutate(
weather_category = case_when(
AWR == 1 ~ "High Risk (AWR=1)",
vsby < 3 ~ "Low Visibility (<3 miles)",
ceiling_ft < 1000 ~ "Low Ceiling (<1000 ft)",
gust > 25 ~ "High Wind (>25 knots)",
TRUE ~ "Normal Conditions"
)
) %>%
group_by(weather_category) %>%
summarise(
avg_delay = mean(as.numeric(LATE_AIRCRAFT_DELAY), na.rm = TRUE),
flights = n(),
se = sd(as.numeric(LATE_AIRCRAFT_DELAY), na.rm = TRUE) / sqrt(n())
) %>%
mutate(weather_category = factor(weather_category,
levels = c("Normal Conditions", "Low Ceiling (<1000 ft)",
"High Wind (>25 knots)", "Low Visibility (<3 miles)",
"High Risk (AWR=1)")))
p2 <- ggplot(delay_by_weather, aes(x = weather_category, y = avg_delay, fill = weather_category)) +
geom_col(width = 0.7) +
geom_errorbar(aes(ymin = avg_delay - se, ymax = avg_delay + se), width = 0.2) +
geom_text(aes(label = round(avg_delay, 1)), vjust = -0.5, size = 4) +
scale_fill_manual(values = c("Normal Conditions" = "#4DAF4A",
"Low Ceiling (<1000 ft)" = "#FF7F00",
"High Wind (>25 knots)" = "#377EB8",
"Low Visibility (<3 miles)" = "#E41A1C",
"High Risk (AWR=1)" = "#984EA3")) +
labs(
title = "Average Propagated Delay by Weather Condition",
subtitle = "Low visibility causes the longest delays",
x = "Weather Condition",
y = "Average Propagated Delay (minutes)",
caption = "Error bars represent ±1 standard error"
) +
theme_minimal() +
theme(
plot.title = element_text(size = 16, face = "bold"),
plot.subtitle = element_text(size = 11, color = "gray40"),
axis.title = element_text(size = 12),
axis.text.x = element_text(angle = 45, hjust = 1, size = 10),
legend.position = "none"
)
ggsave("p2_delay_by_weather.png", p2, width = 10, height = 6, dpi = 300)
print(p2)
# ============================================
# VISUALIZATION 3: Wind Speed vs Propagated Delay (FIXED)
# ============================================
# Create wind category data first
wind_data <- model_data %>%
filter(!is.na(sknt), !is.na(LATE_AIRCRAFT_DELAY), sknt <= 40) %>%
mutate(wind_category = cut(sknt, breaks = c(0, 5, 10, 15, 20, 25, 100),
labels = c("0-5", "6-10", "11-15", "16-20", "21-25", "25+"))) %>%
group_by(wind_category) %>%
summarise(
avg_delay = mean(as.numeric(LATE_AIRCRAFT_DELAY), na.rm = TRUE),
flights = n()
)
# Create color palette for wind categories
wind_colors <- c("0-5" = "#4DAF4A", "6-10" = "#78C679", "11-15" = "#FFD700",
"16-20" = "#FF7F00", "21-25" = "#E41A1C", "25+" = "#8B0000")
p3 <- ggplot(wind_data, aes(x = wind_category, y = avg_delay, fill = wind_category)) +
geom_col(width = 0.7) +
geom_text(aes(label = round(avg_delay, 1)), vjust = -0.5, size = 4) +
scale_fill_manual(values = wind_colors, guide = "none") +
labs(
title = "Wind Speed Impact on Propagated Delay",
subtitle = "Higher wind speeds lead to longer delays",
x = "Wind Speed (knots)",
